---
import type { Edition } from './editions';
interface Props { editions: Edition[]; current: string; }
const { editions, current } = Astro.props;
const fmt = (s: string) => new Date(s).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<div class="vtl-head">// version history</div>
<nav class="vtl">
  {editions.map((e) => (
    <a class={`vtl-item ${e.date === current ? 'active' : ''} ${e.isNote ? 'note' : ''}`} href={e.href}>
      <span class="vtl-dot"></span>
      <span class="vtl-v">v{e.version}{e.isNote && <span class="vtl-tag">note</span>}</span>
      <div class="vtl-date">{fmt(e.date)}</div>
      {e.summary && <div class="vtl-sum">{e.summary}</div>}
    </a>
  ))}
</nav>

---
import '../styles/tokens/index.css';
import '../styles/styles-core.css';
import '../styles/styles-sections.css';
import '../styles/cockpit.css';
import GlobalStarfield from '../components/effects/GlobalStarfield.tsx';

interface Props {
  title?: string;
}

const { title = 'juan_kok — CV v2.0' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
    ></script>
  </head>
  <body>
    <div id="starfield-root">
      <GlobalStarfield client:load />
    </div>
    <slot />
  </body>
</html>

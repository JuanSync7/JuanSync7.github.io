---
import './../components/trackers/_chrome.css';
import Footer from '../components/layout/Footer.astro';
interface Props { title?: string; active?: string; mainWidth?: string; }
const { title = 'Trackers · juan.kok', active = '', mainWidth } = Astro.props;
const links = [
  { id: 'engines', href: '/trackers/inference-engines', label: 'Engines' },
  { id: 'models', href: '/trackers/frontier-models', label: 'Models' },
  { id: 'silicon', href: '/trackers/inference-silicon', label: 'Silicon' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('tracker-theme');
          if (!t) t = matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
        } catch (e) {}
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="sitenav">
      <div class="inner">
        <a class="brand tnav-back" href="/blog"><span class="arr">←</span> juan.kok / blog</a>
        <nav class="navlinks">
          {links.map((l) => <a href={l.href} class={active === l.id ? 'active' : ''}>{l.label}</a>)}
          <a href="/learn">Learn</a>
          <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle light/dark theme">☾</button>
        </nav>
      </div>
    </header>
    <main class="wrap">
      <slot />
      <Footer width={mainWidth} />
    </main>
    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        var root = document.documentElement;
        function sync() { btn.textContent = root.getAttribute('data-theme') === 'light' ? '☼' : '☾'; }
        sync();
        btn.addEventListener('click', function () {
          var light = root.getAttribute('data-theme') === 'light';
          if (light) { root.removeAttribute('data-theme'); }
          else { root.setAttribute('data-theme', 'light'); }
          try { localStorage.setItem('tracker-theme', light ? 'dark' : 'light'); } catch (e) {}
          sync();
        });
      })();
    </script>
  </body>
</html>

  <script is:inline>
    // Resolve hex values for swatches at runtime so the displayed values
    // always match what the tokens actually compute to.
    function rgbToHex(rgb) {
      const m = rgb.match(/rgba?\(([^)]+)\)/);
      if (!m) return rgb;
      const parts = m[1].split(',').map((s) => s.trim());
      const [r, g, b] = parts.slice(0, 3).map(Number);
      const a = parts[3] !== undefined ? Number(parts[3]) : 1;
      const toHex = (n) => Number(n).toString(16).padStart(2, '0');
      const hex = '#' + toHex(r) + toHex(g) + toHex(b);
      return a < 1 ? hex + ' · α' + a.toFixed(2) : hex;
    }
    document.querySelectorAll('[data-resolve-hex]').forEach((el) => {
      const tok = el.getAttribute('data-resolve-hex');
      const val = getComputedStyle(document.documentElement).getPropertyValue(tok).trim();
      if (!val) { el.textContent = '—'; return; }
      if (val.startsWith('#')) { el.textContent = val; return; }
      if (val.startsWith('rgb')) { el.textContent = rgbToHex(val); return; }
      el.textContent = val;
    });

    // Click-to-copy for swatches and gradient cards.
    const toast = document.getElementById('ds-toast');
    let toastTimer;
    function flash(msg) {
      if (!toast) return;
      toast.textContent = msg;
      toast.classList.add('ds-show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove('ds-show'), 1100);
    }
    function copyText(txt) {
      if (!txt) return;
      navigator.clipboard?.writeText(txt).then(
        () => flash('copied: ' + (txt.length > 40 ? txt.slice(0, 38) + '…' : txt)),
        () => flash('copy failed'),
      );
    }
    // Every <code> on the page is click-to-copy (its own textContent).
    document.querySelectorAll('code').forEach((el) => {
      el.classList.add('ds-code-copy');
      el.title = 'click to copy';
      el.addEventListener('click', (e) => {
        e.stopPropagation();
        copyText(el.textContent || '');
      });
    });
    // Snippet modal — every artifact with `data-ds-snippet` opens a modal
    // showing the code needed to reproduce it.
    const modal = document.getElementById('ds-modal');
    const modalCode = document.getElementById('ds-modal-code');
    const modalCopy = document.getElementById('ds-modal-copy');
    let currentSnippet = '';
    function openModal(snippet) {
      if (!modal || !modalCode) return;
      currentSnippet = snippet;
      modalCode.textContent = snippet;
      modal.classList.add('ds-show');
      modal.setAttribute('aria-hidden', 'false');
    }
    function closeModal() {
      if (!modal) return;
      modal.classList.remove('ds-show');
      modal.setAttribute('aria-hidden', 'true');
    }
    document.querySelectorAll('.ds-copyable').forEach((el) => {
      el.addEventListener('click', (e) => {
        const target = e.target;
        if (target instanceof Element && target.closest('code')) return;
        const snippet = el.getAttribute('data-ds-snippet') || el.getAttribute('data-copy') || '';
        if (!snippet) return;
        openModal(snippet);
      });
    });
    document.querySelectorAll('[data-ds-close]').forEach((el) => {
      el.addEventListener('click', closeModal);
    });
    modalCopy?.addEventListener('click', () => copyText(currentSnippet));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });
  </script>

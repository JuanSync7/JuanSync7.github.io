---
import Layout from '../layouts/Layout.astro';
import '../styles/design-system.css';
import NeonText from '../components/ui/NeonText.tsx';
import KineticWord from '../components/ui/KineticWord.tsx';
import StrikeThrough from '../components/ui/StrikeThrough.tsx';
import NotGateDivider from '../components/ui/NotGateDivider.tsx';
import SegmentedBar from '../components/ui/SegmentedBar.tsx';
import PurpleSkyTransition from '../components/ui/PurpleSkyTransition.tsx';
import StarfieldStage from '../components/ui/StarfieldStage.tsx';
import LofiFooterFade from '../components/ui/LofiFooterFade.tsx';
import Placeholder from '../components/ui/Placeholder.tsx';
import NebulaStars from '../components/ui/NebulaStars.tsx';
import { IDENTITY, CAREER_STATS } from '../data/site';

/* All tokens read from src/styles/tokens/*.css. Hex values are resolved
   at runtime by the inline script at the bottom of this page so this list
   stays a single source of truth — never hardcode hex here. */

const COLOR_TOKENS = [
  { group: 'surfaces', tokens: [
    { name: 'bg', token: '--hf-bg' },
    { name: 'bg-2', token: '--hf-bg-2' },
    { name: 'surface', token: '--hf-surface' },
    { name: 'surface-2', token: '--hf-surface-2' },
    { name: 'cockpit-bg', token: '--hf-cockpit-bg' },
    { name: 'cockpit-panel', token: '--hf-cockpit-panel' },
    { name: 'cockpit-panel-2', token: '--hf-cockpit-panel-2' },
  ]},
  { group: 'ink', tokens: [
    { name: 'ink', token: '--hf-ink' },
    { name: 'ink-pale', token: '--hf-ink-pale' },
    { name: 'ink-soft', token: '--hf-ink-soft' },
    { name: 'ink-muted', token: '--hf-ink-muted' },
  ]},
  { group: 'lines', tokens: [
    { name: 'line', token: '--hf-line' },
    { name: 'line-strong', token: '--hf-line-strong' },
  ]},
  { group: 'brand accents', tokens: [
    { name: 'accent (lime)', token: '--hf-accent' },
    { name: 'accent-2 (teal)', token: '--hf-accent-2' },
    { name: 'accent-3 (mint)', token: '--hf-accent-3' },
  ]},
  { group: 'category accents', tokens: [
    { name: 'cp-asic', token: '--cp-asic' },
    { name: 'cp-ai', token: '--cp-ai' },
    { name: 'cp-ai-orange', token: '--cp-ai-orange' },
    { name: 'cp-eda', token: '--cp-eda' },
    { name: 'cp-script', token: '--cp-script' },
    { name: 'cp-ok', token: '--cp-ok' },
  ]},
  { group: 'specialty', tokens: [
    { name: 'terminal-glow', token: '--hf-terminal-glow' },
    { name: 'cyan', token: '--hf-cyan' },
    { name: 'magenta', token: '--hf-magenta' },
    { name: 'violet', token: '--hf-violet' },
  ]},
  { group: 'lofi / purple', tokens: [
    { name: 'purple-deep', token: '--hf-purple-deep' },
    { name: 'purple-mid', token: '--hf-purple-mid' },
    { name: 'purple-shadow', token: '--hf-purple-shadow' },
    { name: 'lofi-accent', token: '--lofi-accent' },
    { name: 'lofi-accent-2', token: '--lofi-accent-2' },
    { name: 'lofi-bg', token: '--lofi-bg' },
  ]},
];

const GRADIENT_TOKENS = [
  { name: 'purple bar',         token: '--hf-grad-purple-bar',        note: 'horizontal sweep for animated section dividers' },
  { name: 'purple bar shadow',  token: '--hf-grad-purple-bar-shadow', note: 'darker mirror of purple bar — drop-shadow under the dividers' },
  { name: 'fade-x',             token: '--hf-grad-fade-x',            note: 'horizontal fade-to-edges mask' },
  { name: 'chart lime → yellow',     token: '--hf-grad-chart-lime-yellow',     note: 'cockpit code-activity bars (GRAD.greenYellow)' },
  { name: 'chart rose → gold',       token: '--hf-grad-chart-rose-gold',       note: 'cockpit donut/speedo accent (GRAD.roseGold)' },
  { name: 'chart periwinkle → mint', token: '--hf-grad-chart-periwinkle-mint', note: 'cockpit donut/speedo accent (GRAD.periwinkleMint)' },
  { name: 'chart coral → purple',    token: '--hf-grad-chart-coral-purple',    note: 'cockpit donut/speedo accent (GRAD.coralPurple)' },
  { name: 'chart cyan → magenta',    token: '--hf-grad-chart-cyan-magenta',    note: 'cockpit donut/speedo accent (GRAD.cyanMagenta)' },
  { name: 'chart emerald → orange',  token: '--hf-grad-chart-emerald-orange',  note: 'cockpit donut/speedo accent (GRAD.emeraldOrange)' },
  { name: 'chart yellow → red',      token: '--hf-grad-chart-yellow-red',      note: 'cockpit donut/speedo accent (GRAD.yellowRed)' },
];

const TYPE_RAMP = [
  { token: '--hf-fs-xs',   px: '10px' },
  { token: '--hf-fs-sm',   px: '11px' },
  { token: '--hf-fs-base', px: '12px' },
  { token: '--hf-fs-md',   px: '13px' },
  { token: '--hf-fs-lg',   px: '14px' },
  { token: '--hf-fs-xl',   px: '16px' },
  { token: '--hf-fs-2xl',  px: '20px' },
];

const SPACING_TOKENS = [
  { token: '--hf-space-1',  px: '4px'  },
  { token: '--hf-space-2',  px: '8px'  },
  { token: '--hf-space-3',  px: '12px' },
  { token: '--hf-space-4',  px: '16px' },
  { token: '--hf-space-5',  px: '20px' },
  { token: '--hf-space-6',  px: '24px' },
  { token: '--hf-space-8',  px: '32px' },
  { token: '--hf-space-10', px: '40px' },
  { token: '--hf-space-12', px: '48px' },
];

const RADIUS_TOKENS = [
  { token: '--hf-radius-xs',   label: '2px'  },
  { token: '--hf-radius-sm',   label: '4px'  },
  { token: '--hf-radius-md',   label: '8px'  },
  { token: '--hf-radius-lg',   label: '12px' },
  { token: '--hf-radius-pill', label: 'pill' },
];

/* Snippet builders — every artifact below carries a `data-ds-snippet`
   string showing the code needed to reproduce it. Click an artifact to
   open the snippet modal. */

const colorSnippet = (token: string, name: string) =>
  `/* ${name} — token from src/styles/tokens/colors.css */
.element {
  background: var(${token});
  /* also: color | border-color | fill | box-shadow color */
}`;

const gradSnippet = (token: string, name: string) =>
  `/* ${name} — token from src/styles/tokens/gradients.css */
.element {
  background: var(${token});
}`;

const fontSnippet = (token: string, label: string) =>
  `/* ${label} — token from src/styles/tokens/typography.css */
.element {
  font-family: var(${token});
}`;

const fontSizeSnippet = (token: string, px: string) =>
  `/* size token (${px}) — typography.css */
.element {
  font-size: var(${token});
}`;

const spacingSnippet = (token: string, px: string) =>
  `/* spacing token (${px}) — spacing.css */
.element {
  padding: var(${token});
  /* also: margin | gap | top/right/bottom/left */
}`;

const radiusSnippet = (token: string, label: string) =>
  `/* radius token (${label}) — spacing.css */
.element {
  border-radius: var(${token});
}`;

const componentImportSnippet = (name: string, importPath: string, usage: string) =>
  `import ${name} from '${importPath}';

// in JSX
${usage}`;

---

<Layout title={`${IDENTITY.shortName} — design system`}>
  <main class="ds-wrap">
    <a href="/" class="ds-back">← back to site</a>

    <header class="ds-header">
      <div class="ds-title">// design_system.sv</div>
      <div class="ds-subtitle">
        Living reference for {IDENTITY.shortName}. Every value below reads from
        the same token files and shared components the production site uses.
        Click any artifact to view the code needed to build it; click any
        inline <code>token</code> label to copy it raw.
      </div>
    </header>

    {/* ───────────────────────── 01 COLOR PALETTE ───────────────────────── */}
    <section class="ds-section">
      <div class="ds-section-title">01 — color palette</div>
      <div class="ds-section-sub">Source: <code>src/styles/tokens/colors.css</code>. Click a swatch to copy <code>var(--token)</code>.</div>

      {COLOR_TOKENS.map((g) => (
        <>
          <div class="ds-group-label">{g.group}</div>
          <div class="ds-swatch-grid">
            {g.tokens.map((c) => (
              <div class="ds-swatch ds-copyable" data-ds-snippet={colorSnippet(c.token, c.name)} title="click for code">
                <div class="ds-swatch-color" style={`background: var(${c.token});`}></div>
                <div class="ds-swatch-info">
                  <div class="ds-swatch-name">{c.name}</div>
                  <div class="ds-swatch-hex" data-resolve-hex={c.token}>—</div>
                  <div class="ds-swatch-var">{c.token}</div>
                </div>
              </div>
            ))}
          </div>
        </>
      ))}
    </section>

    {/* ───────────────────────── 02 GRADIENTS ───────────────────────── */}
    <section class="ds-section">
      <div class="ds-section-title">02 — gradients</div>
      <div class="ds-section-sub">Source: <code>src/styles/tokens/gradients.css</code>.</div>
      <div class="ds-grad-row">
        {GRADIENT_TOKENS.map((g) => (
          <div class="ds-grad-card ds-copyable" data-ds-snippet={gradSnippet(g.token, g.name)} title="click for code">
            <div class="ds-grad-strip" style={`background: var(${g.token});`}></div>
            <div class="ds-grad-info">
              <div class="ds-grad-name">{g.name}</div>
              <div class="ds-grad-code">{g.token}</div>
              <div class="ds-grad-note">{g.note}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* ───────────────────────── 03 TYPOGRAPHY ───────────────────────── */}
    <section class="ds-section">
      <div class="ds-section-title">03 — typography</div>
      <div class="ds-section-sub">Source: <code>src/styles/tokens/typography.css</code>.</div>

      <div class="ds-font-row">
        <div class="ds-font-card ds-copyable" data-ds-snippet={fontSnippet('--hf-mono', 'JetBrains Mono — primary')} title="click for code">
          <div class="ds-font-label">--hf-mono · primary</div>
          <div class="ds-font-display" style="font-family: var(--hf-mono); font-size: 24px;">JetBrains Mono</div>
          <div class="ds-font-sample" style="font-family: var(--hf-mono);">
            ABCDEFGHIJKLM abcdefghijklm 0123456789<br/>
            The quick brown fox jumps over the lazy dog.
          </div>
          <div class="ds-font-meta">Body, code, labels, nav, dashboard UI · 400/500/600/700</div>
        </div>
        <div class="ds-font-card ds-copyable" data-ds-snippet={fontSnippet('--hf-display', 'Special Elite — display')} title="click for code">
          <div class="ds-font-label">--hf-display · display</div>
          <div class="ds-font-display" style="font-family: var(--hf-display); font-size: 32px;">Special Elite</div>
          <div class="ds-font-sample" style="font-family: var(--hf-display);">
            ABCDEFGHIJKLM abcdefghijklm 0123456789<br/>
            The quick brown fox jumps over the lazy dog.
          </div>
          <div class="ds-font-meta">Hero headings, project titles, signature badge</div>
        </div>
        <div class="ds-font-card ds-copyable" data-ds-snippet={fontSnippet('--hf-hand', 'Caveat — handwritten')} title="click for code">
          <div class="ds-font-label">--hf-hand · handwritten</div>
          <div class="ds-font-display" style="font-family: var(--hf-hand); font-size: 28px;">Caveat</div>
          <div class="ds-font-sample" style="font-family: var(--hf-hand); font-size: 16px;">
            ABCDEFGHIJKLM abcdefghijklm 0123456789<br/>
            The quick brown fox jumps over the lazy dog.
          </div>
          <div class="ds-font-meta">Lofi annotations, casual accents · 400/600</div>
        </div>
      </div>

      <div class="ds-group-label" style="margin-top: 24px;">size scale</div>
      <div class="ds-type-ramp">
        {TYPE_RAMP.map((t) => (
          <div class="ds-type-row ds-copyable" data-ds-snippet={fontSizeSnippet(t.token, t.px)} title="click for code">
            <span class="ds-type-label">{t.token}</span>
            <span class="ds-type-px">{t.px}</span>
            <span class="ds-type-sample" style={`font-size: var(${t.token});`}>The quick brown fox jumps over the lazy dog.</span>
          </div>
        ))}
      </div>
    </section>

    {/* ───────────────────────── 04 ATMOSPHERIC EFFECTS ───────────────────────── */}
    <section class="ds-section">
      <div class="ds-section-title">04 — atmospheric effects</div>
      <div class="ds-section-sub">Live components from <code>src/components/ui/</code>. Each one self-positions — drop it anywhere.</div>

      <div class="ds-atmo-stack">
        <div class="ds-atmo-item">
          <div class="ds-atmo-stage ds-atmo-stage-band ds-atmo-stage-starfield ds-copyable" data-ds-snippet={componentImportSnippet('StarfieldStage', '../components/ui/StarfieldStage', '<StarfieldStage client:load />')} title="click for code">
            <StarfieldStage client:load />
          </div>
          <div class="ds-atmo-cap">&lt;StarfieldStage&gt; — twinkling stars + periodic shooting stars on black bg (scoped canvas; the global version is wired in <code>Layout.astro</code>)</div>
        </div>
        <div class="ds-atmo-item">
          <div class="ds-atmo-stage ds-copyable" data-ds-snippet={componentImportSnippet('PurpleSkyTransition', '../components/ui/PurpleSkyTransition', '<PurpleSkyTransition client:load />')} title="click for code"><PurpleSkyTransition client:load /></div>
          <div class="ds-atmo-cap">&lt;PurpleSkyTransition&gt; — dark to deep-purple sky with stars</div>
        </div>
        <div class="ds-atmo-item">
          <div class="ds-atmo-stage ds-copyable" data-ds-snippet={componentImportSnippet('LofiFooterFade', '../components/ui/LofiFooterFade', '<LofiFooterFade client:load />')} title="click for code"><LofiFooterFade client:load /></div>
          <div class="ds-atmo-cap">&lt;LofiFooterFade&gt; — purple → page bg fade with drifting dots, between lofi room and footer</div>
        </div>
        <div class="ds-atmo-item">
          <div class="ds-atmo-stage ds-atmo-stage-band hf-band-cosmic ds-copyable" data-ds-snippet={`import NebulaStars from '../components/ui/NebulaStars';

// in JSX — backdrop class + nebula stars layered on top
<div class="hf-band-cosmic">
  <NebulaStars client:load count={40} />
</div>`} title="click for code">
            <NebulaStars client:load count={40} />
          </div>
          <div class="ds-atmo-cap">.hf-band-cosmic + &lt;NebulaStars&gt; — cockpit cosmic backdrop, <code>var(--hf-grad-cockpit)</code></div>
        </div>
        <div class="ds-atmo-item">
          <div class="ds-atmo-stage ds-atmo-stage-band hf-band-nebula ds-copyable" data-ds-snippet={`import NebulaStars from '../components/ui/NebulaStars';

// in JSX — backdrop class + nebula stars layered on top
<div class="hf-band-nebula">
  <NebulaStars client:load count={40} />
</div>`} title="click for code">
            <NebulaStars client:load count={40} />
          </div>
          <div class="ds-atmo-cap">.hf-band-nebula + &lt;NebulaStars&gt; — terminal nebula backdrop, <code>var(--hf-grad-nebula)</code></div>
        </div>
      </div>
    </section>

    {/* ───────────────────────── 05 CONTAINERS ───────────────────────── */}
    <section class="ds-section">
      <div class="ds-section-title">05 — containers</div>
      <div class="ds-section-sub">Common surface treatments. All values come from tokens — no inline hex.</div>

      <div class="ds-container-grid">
        <div class="ds-container-demo ds-copyable" data-ds-snippet={`/* cp-dash — cockpit dashboard panel */
.cp-dash {
  background: var(--hf-cockpit-bg);
  border: 1px solid var(--hf-alpha-white-06);
  border-radius: var(--hf-radius-lg);
  box-shadow:
    inset 0 0 60px rgba(0, 229, 255, 0.04),
    inset 0 0 120px rgba(168, 85, 247, 0.03),
    inset 0 1px 0 var(--hf-alpha-white-05),
    0 0 40px var(--hf-alpha-black-40);
}`} title="click for code" style="background: var(--hf-cockpit-bg); border: 1px solid var(--hf-alpha-white-06); border-radius: var(--hf-radius-lg); box-shadow: inset 0 0 60px rgba(0,229,255,0.04), inset 0 0 120px rgba(168,85,247,0.03), inset 0 1px 0 var(--hf-alpha-white-05), 0 0 40px var(--hf-alpha-black-40);">
          <div class="ds-container-label">cp-dash</div>
          <div class="ds-container-desc">Cockpit dashboard panel — flat dark bg with cyan + purple inner glow.</div>
          <div class="ds-container-meta">bg: --hf-cockpit-bg · border: --hf-alpha-white-06 · radius: --hf-radius-lg</div>
        </div>
        <div class="ds-container-demo ds-copyable" data-ds-snippet={`/* terminal — window with traffic lights */
.terminal {
  background: #080c0a;
  border: 1.5px solid var(--hf-line-strong);
  border-radius: var(--hf-radius-md);
}
.terminal .traffic { display: flex; gap: 6px; }
.terminal .traffic span {
  width: 10px; height: 10px; border-radius: 50%;
}
.terminal .traffic .red    { background: #ff5f57; }
.terminal .traffic .yellow { background: #febc2e; }
.terminal .traffic .green  { background: #28c840; }`} title="click for code" style="background: #080c0a; border: 1.5px solid var(--hf-line-strong); border-radius: var(--hf-radius-md);">
          <div class="ds-container-label">terminal</div>
          <div class="ds-container-desc">Terminal window — near-black bg with traffic lights.</div>
          <div class="ds-traffic-row">
            <span class="ds-traffic" style="background: #ff5f57;"></span>
            <span class="ds-traffic" style="background: #febc2e;"></span>
            <span class="ds-traffic" style="background: #28c840;"></span>
          </div>
          <div class="ds-container-meta">border: --hf-line-strong · radius: --hf-radius-md</div>
        </div>
        <div class="ds-container-demo ds-copyable" data-ds-snippet={`/* card — project / stat surface */
.card {
  background: var(--hf-surface);
  border: 1.5px solid var(--hf-line);
  border-radius: var(--hf-radius-md);
}`} title="click for code" style="background: var(--hf-surface); border: 1.5px solid var(--hf-line); border-radius: var(--hf-radius-md);">
          <div class="ds-container-label">card</div>
          <div class="ds-container-desc">Project cards, stat cards — surface bg, thin border.</div>
          <div class="ds-container-meta">bg: --hf-surface · border: --hf-line · radius: --hf-radius-md</div>
        </div>
        <div class="ds-container-demo ds-copyable" data-ds-snippet={`/* block — terminal output, accent left rule */
.block {
  background: var(--hf-alpha-white-02);
  border: 1.5px solid var(--hf-cockpit-panel-2);
  border-left: 3px solid var(--hf-accent);
  border-radius: var(--hf-radius-sm);
  padding-left: 12px;
}`} title="click for code" style="background: var(--hf-alpha-white-02); border: 1.5px solid var(--hf-cockpit-panel-2); border-radius: var(--hf-radius-sm); border-left: 3px solid var(--hf-accent); padding-left: 12px;">
          <div class="ds-container-label">block</div>
          <div class="ds-container-desc">Terminal output block — accent left border, near-transparent bg.</div>
          <div class="ds-container-meta">border-left: 3px solid --hf-accent · bg: --hf-alpha-white-02</div>
        </div>
      </div>

    </section>

    {/* ───────────────────────── 06 UI COMPONENTS ───────────────────────── */}
    <section class="ds-section">
      <div class="ds-section-title">06 — UI components</div>
      <div class="ds-section-sub">
        Live previews from <code>src/components/ui/</code>. Every shared component <em>must</em> appear here —
        new components added without a preview don't count as reusable.
      </div>

      <div class="ds-comp-grid">
        <div class="ds-comp-card ds-copyable" data-ds-snippet={componentImportSnippet('NeonText', '../components/ui/NeonText', '<NeonText client:load>NEON_TEXT</NeonText>')} title="click for code">
          <div class="ds-comp-label">&lt;NeonText&gt;</div>
          <div class="ds-comp-stage ds-comp-stage-display"><NeonText client:load>NEON_TEXT</NeonText></div>
          <div class="ds-comp-note">flickering accent — wraps any inline text</div>
        </div>

        <div class="ds-comp-card ds-copyable" data-ds-snippet={componentImportSnippet('KineticWord', '../components/ui/KineticWord', '<KineticWord client:load word="kinetic" altWord="glitched" delay={1500} loop />')} title="click for code">
          <div class="ds-comp-label">&lt;KineticWord&gt;</div>
          <div class="ds-comp-stage ds-comp-stage-display"><KineticWord client:load word="kinetic" altWord="glitched" delay={1500} loop={true} /></div>
          <div class="ds-comp-note">strike-then-replace cycle</div>
        </div>

        <div class="ds-comp-card ds-copyable" data-ds-snippet={componentImportSnippet('StrikeThrough', '../components/ui/StrikeThrough', '<StrikeThrough client:load delay={800}>strike-through copy</StrikeThrough>')} title="click for code">
          <div class="ds-comp-label">&lt;StrikeThrough&gt;</div>
          <div class="ds-comp-stage ds-comp-stage-display"><StrikeThrough client:load delay={800}>strike-through copy</StrikeThrough></div>
          <div class="ds-comp-note">animated cross-out on mount</div>
        </div>

        <div class="ds-comp-card ds-copyable" data-ds-snippet={componentImportSnippet('NotGateDivider', '../components/ui/NotGateDivider', '<NotGateDivider client:load label="design_system.boundary" />')} title="click for code">
          <div class="ds-comp-label">&lt;NotGateDivider&gt;</div>
          <div class="ds-comp-stage"><NotGateDivider client:load label="design_system.boundary" /></div>
          <div class="ds-comp-note">section divider with logic-gate motif</div>
        </div>

        <div class="ds-comp-card ds-comp-card-wide ds-copyable" data-ds-snippet={`import SegmentedBar from '../components/ui/SegmentedBar';

// in JSX
<SegmentedBar client:load value={3} max={5} segments={5} />
<SegmentedBar client:load value={7} max={10} segments={10} color="var(--cp-ai)" />
<SegmentedBar client:load value={9} max={10} segments={10} color="var(--cp-eda)" />`} title="click for code">
          <div class="ds-comp-label">&lt;SegmentedBar&gt;</div>
          <div class="ds-comp-stage ds-comp-stage-stack">
            <SegmentedBar client:load value={3} max={5} segments={5} />
            <SegmentedBar client:load value={7} max={10} segments={10} color="var(--cp-ai)" />
            <SegmentedBar client:load value={9} max={10} segments={10} color="var(--cp-eda)" />
          </div>
          <div class="ds-comp-note">value / max / color / segments — used in cockpit meters</div>
        </div>

        <div class="ds-comp-card ds-copyable" data-ds-snippet={componentImportSnippet('Placeholder', '../components/ui/Placeholder', '<Placeholder client:load name="placeholder.module" />')} title="click for code">
          <div class="ds-comp-label">&lt;Placeholder&gt;</div>
          <div class="ds-comp-stage"><Placeholder client:load name="placeholder.module" /></div>
          <div class="ds-comp-note">fallback panel for missing/loading content</div>
        </div>

        <div class="ds-comp-card ds-copyable" data-ds-snippet={`/* stat card — cockpit vitals tile */
.stat-card {
  flex: 1;
  padding: var(--hf-space-3);
